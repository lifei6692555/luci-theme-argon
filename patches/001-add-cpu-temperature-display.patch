--- a/luci-theme-argon/htdocs/luci-static/resources/view/status/include/15_cpuinfo.js
+++ b/luci-theme-argon/htdocs/luci-static/resources/view/status/include/15_cpuinfo.js
@@ -0,0 +1,152 @@
+'use strict';
+'require baseclass';
+'require fs';
+'require rpc';
+
+var callSystemInfo = rpc.declare({
+	object: 'system',
+	method: 'info'
+});
+
+/* Max thermal zones to scan (covers CPU + WiFi radios on most devices) */
+var THERMAL_ZONES = 4;
+
+function progressbar(value, max) {
+	var vn = parseInt(value) || 0,
+	    mn = parseInt(max) || 100,
+	    pc = Math.floor((100 / mn) * vn);
+
+	return E('div', {
+		'class': 'cbi-progressbar',
+		'title': '%d%% (%d / %d)'.format(pc, vn, mn)
+	}, E('div', { 'style': 'width:%.2f%%'.format(pc) }));
+}
+
+function parseThermalZone(tempResult, typeResult) {
+	if (!tempResult || tempResult.code !== 0 || !tempResult.stdout)
+		return null;
+
+	var temp = parseInt(tempResult.stdout.trim());
+	if (isNaN(temp) || temp <= 0)
+		return null;
+
+	var type = 'Unknown';
+	if (typeResult && typeResult.code === 0 && typeResult.stdout)
+		type = typeResult.stdout.trim();
+
+	return { temp: (temp / 1000).toFixed(1), type: type };
+}
+
+function formatZoneLabel(type) {
+	if (/cpu|soc|x86|pkg|processor|coretemp/i.test(type))
+		return _('CPU Temperature');
+
+	if (/mt76|ath[0-9]|iwl|wifi|wlan|phy/i.test(type))
+		return _('WiFi Temperature') + ' (' + type + ')';
+
+	return _('Temperature') + ' (' + type + ')';
+}
+
+return baseclass.extend({
+	title: _('CPU'),
+
+	prevIdle: 0,
+	prevTotal: 0,
+
+	load: function() {
+		var promises = [];
+
+		for (var i = 0; i < THERMAL_ZONES; i++) {
+			promises.push(L.resolveDefault(fs.exec('/bin/cat', ['/sys/class/thermal/thermal_zone' + i + '/temp']), null));
+			promises.push(L.resolveDefault(fs.exec('/bin/cat', ['/sys/class/thermal/thermal_zone' + i + '/type']), null));
+		}
+
+		promises.push(L.resolveDefault(fs.exec('/usr/bin/head', ['-1', '/proc/stat']), null));
+		promises.push(L.resolveDefault(callSystemInfo(), {}));
+
+		return Promise.all(promises);
+	},
+
+	render: function(data) {
+		var fields = [];
+
+		var temps = [];
+		for (var i = 0; i < THERMAL_ZONES; i++) {
+			var zone = parseThermalZone(data[i * 2], data[i * 2 + 1]);
+			if (zone)
+				temps.push(zone);
+		}
+
+		var statIdx = THERMAL_ZONES * 2;
+		var sysIdx = THERMAL_ZONES * 2 + 1;
+		var statResult = data[statIdx];
+		var systemInfo = data[sysIdx];
+
+		// Parse CPU usage
+		var cpuUsage = null;
+		if (statResult && statResult.code === 0 && statResult.stdout) {
+			var line = statResult.stdout.trim();
+			if (line.indexOf('cpu ') === 0) {
+				var parts = line.split(/\s+/);
+				var user = parseInt(parts[1]) || 0;
+				var nice = parseInt(parts[2]) || 0;
+				var system = parseInt(parts[3]) || 0;
+				var idle = parseInt(parts[4]) || 0;
+				var iowait = parseInt(parts[5]) || 0;
+				var irq = parseInt(parts[6]) || 0;
+				var softirq = parseInt(parts[7]) || 0;
+				var steal = parseInt(parts[8]) || 0;
+
+				var idleTime = idle + iowait;
+				var totalTime = user + nice + system + idle + iowait + irq + softirq + steal;
+
+				var diffIdle = idleTime - this.prevIdle;
+				var diffTotal = totalTime - this.prevTotal;
+
+				if (diffTotal > 0 && this.prevTotal > 0) {
+					cpuUsage = Math.round((1 - diffIdle / diffTotal) * 100);
+				} else if (this.prevTotal === 0) {
+					cpuUsage = 0;
+				}
+
+				this.prevIdle = idleTime;
+				this.prevTotal = totalTime;
+			}
+		}
+
+		// Fallback: use load average
+		if (cpuUsage === null && systemInfo && systemInfo.load) {
+			var load1 = systemInfo.load[0] / 65535.0;
+			cpuUsage = Math.min(Math.round(load1 * 100), 100);
+		}
+
+		// CPU usage
+		if (cpuUsage !== null) {
+			fields.push(_('CPU usage (%)'));
+			fields.push(progressbar(cpuUsage, 100));
+		}
+
+		// All temperatures (CPU + WiFi + others)
+		for (var i = 0; i < temps.length; i++) {
+			fields.push(formatZoneLabel(temps[i].type));
+			fields.push(temps[i].temp + ' °C');
+		}
+
+		if (fields.length === 0) {
+			return null;
+		}
+
+		var table = E('table', { 'class': 'table' });
+
+		for (var i = 0; i < fields.length; i += 2) {
+			table.appendChild(E('tr', { 'class': 'tr' }, [
+				E('td', { 'class': 'td left', 'width': '33%' }, [ fields[i] ]),
+				E('td', { 'class': 'td left' }, [
+					(fields[i + 1] !== null) ? fields[i + 1] : '?'
+				])
+			]));
+		}
+
+		return table;
+	}
+});
--- a/luci-theme-argon/root/usr/share/rpcd/acl.d/luci-theme-argon.json
+++ b/luci-theme-argon/root/usr/share/rpcd/acl.d/luci-theme-argon.json
@@ -2,7 +2,12 @@
     "luci-theme-argon": {
         "description": "Grant UCI access for luci-theme-argon",
         "read": {
-            "uci": [ "argon" ]
+            "uci": [ "argon" ],
+            "file": {
+                "/bin/cat /sys/class/thermal/thermal_zone*/temp": [ "exec" ],
+                "/bin/cat /sys/class/thermal/thermal_zone*/type": [ "exec" ],
+                "/usr/bin/head -1 /proc/stat": [ "exec" ]
+            }
         }
     }
 }
